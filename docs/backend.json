
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "User-specific settings and personalization preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Matches the User UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's chosen display name."
        },
        "studentType": {
          "type": "string",
          "enum": ["high-school", "college"],
          "description": "The educational level of the user."
        },
        "blackbaudConnected": {
          "type": "boolean",
          "description": "Whether the user has connected their blackbaud account."
        },
        "useAi": {
          "type": "boolean",
          "description": "Whether the user wants to enable generative AI features."
        },
        "focus": {
          "type": "string",
          "enum": ["flashcards", "notebooks", "tasks", "all"],
          "description": "The primary tool the user wants to focus on."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has administrative privileges."
        }
      },
      "required": [
        "id",
        "studentType",
        "useAi",
        "focus"
      ]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents an academic course or subject.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "grade": {
          "type": "number"
        },
        "letterGrade": {
          "type": "string"
        },
        "credits": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "An academic task or to-do item.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "completed": {
          "type": "boolean"
        },
        "courseId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "title", "dueDate", "priority", "completed"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/profile/settings",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User personalization preferences."
        }
      },
      {
        "path": "/users/{userId}/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": {
            "$ref": "#/backend/entities/Course"
          },
          "description": "User-specific collection of academic courses."
        }
      },
      {
        "path": "/users/{userId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/backend/entities/Task"
          },
          "description": "User tasks and deadlines."
        }
      }
    ]
  }
}
