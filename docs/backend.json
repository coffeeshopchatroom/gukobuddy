
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "User-specific settings and personalization preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Matches the User UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's chosen display name."
        },
        "studentType": {
          "type": "string",
          "enum": ["high-school", "college", "hobbyist"],
          "description": "The educational level or usage mode of the user."
        },
        "selectedAvatar": {
          "type": "string",
          "description": "The ID of the chosen avatar (e.g., mii-m2)."
        },
        "blackbaudConnected": {
          "type": "boolean",
          "description": "Whether the user has connected their blackbaud account."
        },
        "useAi": {
          "type": "boolean",
          "description": "Whether the user wants to enable generative AI features."
        },
        "focus": {
          "type": "string",
          "enum": ["flashcards", "notebooks", "tasks", "all"],
          "description": "The primary tool the user wants to focus on."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Whether the user has administrative privileges."
        },
        "focusHours": {
          "type": "number",
          "description": "Total hours spent focusing (for hobbyists)."
        },
        "studyStreak": {
          "type": "number",
          "description": "Consecutive days of engagement (for hobbyists)."
        },
        "stickyNote": {
          "type": "string",
          "description": "Quick dashboard thoughts (for hobbyists)."
        },
        "theme": {
          "type": "object",
          "properties": {
            "activeTheme": { "type": "string" },
            "customColors": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "background": { "type": "string" },
                "accent": { "type": "string" },
                "foreground": { "type": "string" },
                "muted": { "type": "string" }
              }
            },
            "backgroundImage": { "type": "string" },
            "bgOpacity": { "type": "number" },
            "bgBlur": { "type": "number" },
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "string", "enum": ["sm", "base", "lg", "xl"] }
          }
        }
      },
      "required": [
        "id",
        "studentType",
        "useAi",
        "focus"
      ]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "description": "Represents an academic course or subject.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "grade": {
          "type": "number"
        },
        "letterGrade": {
          "type": "string"
        },
        "credits": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Task": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Task",
      "type": "object",
      "description": "An academic task or to-do item.",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "dueDate": {
          "type": "string",
          "format": "date-time"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "completed": {
          "type": "boolean"
        },
        "courseId": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "title", "dueDate", "priority", "completed"]
    },
    "Note": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Note",
      "type": "object",
      "description": "A digital note or page.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string", "description": "HTML content from the rich text editor." },
        "icon": { "type": "string" },
        "coverImage": { "type": "string" },
        "iconType": { "type": "string", "enum": ["emoji", "icon", "image"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/profile/settings",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User personalization preferences."
        }
      },
      {
        "path": "/users/{userId}/courses/{courseId}",
        "definition": {
          "entityName": "Course",
          "schema": {
            "$ref": "#/backend/entities/Course"
          },
          "description": "User-specific collection of academic courses."
        }
      },
      {
        "path": "/users/{userId}/tasks/{taskId}",
        "definition": {
          "entityName": "Task",
          "schema": {
            "$ref": "#/backend/entities/Task"
          },
          "description": "User tasks and deadlines."
        }
      },
      {
        "path": "/users/{userId}/notes/{noteId}",
        "definition": {
          "entityName": "Note",
          "schema": {
            "$ref": "#/backend/entities/Note"
          },
          "description": "User digital notes and pages."
        }
      }
    ]
  }
}
