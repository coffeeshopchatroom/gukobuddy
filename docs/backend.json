
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "User-specific settings and personalization preferences.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Matches the User UID."
        },
        "displayName": {
          "type": "string",
          "description": "The user's chosen display name."
        },
        "username": {
          "type": "string",
          "description": "Unique username for searching."
        },
        "studentType": {
          "type": "string",
          "enum": ["high-school", "college", "hobbyist"],
          "description": "The educational level or usage mode of the user."
        },
        "selectedAvatar": {
          "type": "string",
          "description": "The ID of the chosen avatar (e.g., mii-m2)."
        },
        "theme": {
          "type": "object",
          "properties": {
            "activeTheme": { "type": "string" },
            "customColors": {
              "type": "object",
              "properties": {
                "primary": { "type": "string" },
                "background": { "type": "string" },
                "accent": { "type": "string" },
                "foreground": { "type": "string" },
                "muted": { "type": "string" }
              }
            },
            "backgroundImage": { "type": "string" },
            "bgOpacity": { "type": "number" },
            "bgBlur": { "type": "number" },
            "fontFamily": { "type": "string" },
            "fontSize": { "type": "string", "enum": ["sm", "base", "lg", "xl"] }
          }
        }
      },
      "required": ["id", "studentType", "username"]
    },
    "Friend": {
      "title": "Friend",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["accepted", "pending_out", "pending_in"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "status"]
    },
    "Chat": {
      "title": "Chat",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "share-invite"] },
        "shareData": {
          "type": "object",
          "properties": {
            "itemType": { "type": "string", "enum": ["notebook", "flashcardSet", "task"] },
            "itemId": { "type": "string" },
            "itemName": { "type": "string" },
            "mode": { "type": "string", "enum": ["copy", "collaborate"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "type", "createdAt"]
    },
    "SharedItem": {
      "title": "SharedItem",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUid": { "type": "string" },
        "toUid": { "type": "string" },
        "itemType": { "type": "string", "enum": ["notebook", "flashcardSet", "task"] },
        "itemId": { "type": "string" },
        "itemData": { "type": "object" },
        "mode": { "type": "string", "enum": ["copy", "collaborate"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fromUid", "toUid", "itemType", "itemId", "mode"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}/profile/settings",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User personalization preferences."
        }
      },
      {
        "path": "/users/{userId}/friends/{friendId}",
        "definition": {
          "entityName": "Friend",
          "schema": { "$ref": "#/backend/entities/Friend" },
          "description": "Friends and pending requests."
        }
      },
      {
        "path": "/chats/{chatId}",
        "definition": {
          "entityName": "Chat",
          "schema": { "$ref": "#/backend/entities/Chat" },
          "description": "Conversation between two students."
        }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Individual messages in a chat."
        }
      },
      {
        "path": "/sharedItems/{shareId}",
        "definition": {
          "entityName": "SharedItem",
          "schema": { "$ref": "#/backend/entities/SharedItem" },
          "description": "Shared learning resources."
        }
      }
    ]
  }
}
