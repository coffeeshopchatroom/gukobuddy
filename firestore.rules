
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    match /users/{userId} {
      // Allow the user to read and write their own document
      allow get, write: if isOwner(userId);

      // Recursive match: Allow the user full access to all sub-collections in their own tree
      // This covers tasks, courses, profile settings, and flashcards.
      match /{allPaths=**} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Maintain specific validation for creation of core entities if needed
      match /courses/{courseId} {
        allow create: if isOwner(userId) && request.resource.data.id == courseId;
      }

      match /tasks/{taskId} {
        allow create: if isOwner(userId) && request.resource.data.id == taskId;
      }
    }
  }
}
