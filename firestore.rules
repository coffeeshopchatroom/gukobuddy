
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows collection group queries for searching profiles by username
    match /{path=**}/profile/{docId} {
      allow read: if request.auth != null;
    }

    // Explicit rules for user settings
    match /users/{userId}/profile/settings {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests logic: Allow users to 'knock' on others' collections
    match /users/{userId}/friends/{friendId} {
      // Users can manage their own friends list (read/write)
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow others to 'knock' (send a pending request)
      // OR allow the recipient to mark themselves as accepted/declined in the sender's list
      // They can create/update/delete the document if friendId matches their UID
      allow create, update, delete: if request.auth != null && friendId == request.auth.uid;
        
      // Allow users to see their own status in someone else's list (e.g., to see if they already sent a request)
      allow read: if request.auth != null && friendId == request.auth.uid;
    }

    // User-specific data (tasks, courses, notebooks)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Chats and messaging rules - Optimized using chatId string parsing for participant verification
    match /chats/{chatId} {
      // Helper to check if the authenticated user is one of the two UIDs in the chatId
      function isParticipant() {
        return request.auth != null && (request.auth.uid in chatId.split('_'));
      }

      allow read, write: if isParticipant();
      
      match /messages/{messageId} {
        allow read, write: if isParticipant();
      }
    }

    // Shared items rules
    match /sharedItems/{shareId} {
      allow read: if request.auth != null && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }
    
    // Global fallback: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
