rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allows collection group queries for searching profiles by username
    // This matches the 'settings' document within any 'profile' collection
    match /{path=**}/profile/{docId} {
      allow read: if request.auth != null;
    }

    // Explicit rules for user settings
    match /users/{userId}/profile/settings {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend requests logic: Allow users to 'knock' on others' collections
    match /users/{userId}/friends/{friendId} {
      // Users can manage their own friends list
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      // Allow creation if it's the owner OR if someone is sending a pending_in request
      // friendId must match the requester's UID in the pending_in case
      allow create: if request.auth != null && (
        request.auth.uid == userId || 
        (request.resource.data.status == 'pending_in' && friendId == request.auth.uid)
      );
    }

    // User-specific data (tasks, courses, notebooks)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shared items rules
    match /sharedItems/{shareId} {
      // Users can read if they are the sender or the recipient
      allow read: if request.auth != null && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      // Users can create if they are the sender
      allow create: if request.auth != null && request.resource.data.fromUid == request.auth.uid;
      // Shared items are immutable for now to ensure integrity
      allow update, delete: if false;
    }
    
    // Global fallback: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}