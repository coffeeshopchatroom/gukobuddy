
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isExistingOwner(ownerId) {
      return resource != null && isOwner(ownerId);
    }

    match /users/{userId} {
      match /profile/settings {
        allow get: if isOwner(userId);
        allow write: if isOwner(userId);
      }

      match /courses/{courseId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == courseId;
        allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
        allow delete: if isExistingOwner(userId);

        match /flashcardSets/{flashcardSetId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isOwner(userId) 
                        && request.resource.data.id == flashcardSetId
                        && request.resource.data.courseId == courseId;
          allow update: if isExistingOwner(userId) 
                        && request.resource.data.id == resource.data.id
                        && request.resource.data.courseId == resource.data.courseId;
          allow delete: if isExistingOwner(userId);

          match /flashcards/{flashcardId} {
            allow get: if isOwner(userId);
            allow list: if isOwner(userId);
            allow create: if isOwner(userId) 
                          && request.resource.data.id == flashcardId
                          && request.resource.data.flashcardSetId == flashcardSetId;
            allow update: if isExistingOwner(userId) 
                          && request.resource.data.id == resource.data.id
                          && request.resource.data.flashcardSetId == resource.data.flashcardSetId;
            allow delete: if isExistingOwner(userId);
          }
        }
      }
    }
  }
}
